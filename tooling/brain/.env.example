# Clé API Anthropic du workspace où vit le brain (Managed Agents).
# Doit être le MÊME workspace que celui de l'agent coach. Jamais commitée.
ANTHROPIC_API_KEY=sk-ant-...

# (Optionnel) Id de l'agent à cibler par défaut (brain:pull, brain:agent:apply).
# Si absent, brain:pull dumpe tous les agents du workspace.
BRAIN_AGENT_ID=
