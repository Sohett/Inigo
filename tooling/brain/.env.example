# Clé API Anthropic du workspace où vit le brain (Managed Agents).
# Doit être le MÊME workspace que celui de l'agent coach. Jamais commitée.
ANTHROPIC_API_KEY=sk-ant-...

# (Optionnel) Id de l'agent à cibler par défaut (brain:pull, brain:agent:apply).
# Si absent, brain:pull dumpe tous les agents du workspace.
BRAIN_AGENT_ID=

# --- Seed one-off du store athlète vers Neon (brain:memory:seed, INI-18) -----
# Connexion Neon. Requise pour `brain:memory:seed --apply`. Jamais commitée.
DATABASE_URL=

# Identité / routing de l'athlète écrits dans la table `athlete` (jamais commités).
# ATHLETE_PHONE_NUM est requis pour --apply (clé de routage E.164).
ATHLETE_DISPLAY_NAME=Thomas Sohet
ATHLETE_PHONE_NUM=
ATHLETE_CHAT_ID=
ATHLETE_SESSION_ID=
ATHLETE_MANAGED_AGENT_ID=
