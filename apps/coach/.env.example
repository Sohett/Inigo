# --- Anthropic Managed Agent (the coach brain) ---
ANTHROPIC_API_KEY=sk-ant-change_me
# No fixed session id: each inbound message is routed to the session resolved for
# its athlete by phone_num (in Neon). See @inigo/db and the routeInboundMessage use-case.

# --- WhatsApp webhook (OpenWA) ---
# Optional: shared secret to verify the X-OpenWA-Signature HMAC.
# If left empty, signature verification is skipped (MVP relies on a non-guessable
# URL + the gateway's "Sender is …" filter). Min 16 chars when set.
WHATSAPP_WEBHOOK_SECRET=

# --- Database (Neon Postgres, shared coaching DB via @inigo/db) ---
# Neon connection string. Server-side only.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Base64-encoded 32-byte key for AES-256-GCM sealing of per-athlete secrets.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DB_ENCRYPTION_KEY=

# --- MCP endpoints (the brain reads/writes here) ---
# Bearer token the brain must present at /api/mcp (athlete-data) and
# /api/intervals/mcp (Intervals.icu). Min 16 chars, server-side only.
MCP_BEARER_TOKEN=

# --- Intervals.icu MCP (/api/intervals/mcp) ---
# Optional override of the Intervals.icu API base URL. Defaults to
# https://intervals.icu/api/v1. Each athlete's own key is resolved from Neon at
# request time (athlete_credential), so no global Intervals key lives here.
INTERVALS_BASE_URL=
