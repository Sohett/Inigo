---
import { requirements } from "@/content/copy";
---

<section id="prerequis" class="scroll-mt-20 bg-secondary/40 px-6">
  <div class="mx-auto max-w-5xl py-24 sm:py-32">
    <div class="max-w-3xl">
      <p class="eyebrow reveal text-encre-soft">{requirements.eyebrow}</p>
      <h2 class="reveal mt-5 text-3xl font-bold sm:text-4xl">{requirements.title}</h2>
      <p class="reveal mt-6 text-lg leading-relaxed text-muted-foreground">{requirements.intro}</p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-3">
      {
        requirements.items.map((item, index) => (
          <div
            class="reveal rounded-2xl border border-border bg-card p-6"
            style={`--delay:${index * 60}ms`}
          >
            <span class="font-mono text-sm text-encre-soft">{String(index + 1).padStart(2, "0")}</span>
            <h3 class="mt-3 font-display text-lg font-semibold">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{item.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
