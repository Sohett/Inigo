---
/**
 * Visuel signature du hero : photo plein cadre + démo produit (maquette WhatsApp).
 * Remplace l'ancienne carte « courbe de puissance ».
 *
 * Responsive :
 *  - < lg  : carte photo + téléphone WhatsApp centré et réduit ; chip et carte
 *            stats masqués.
 *  - ≥ lg  : composition complète (téléphone débordant en bas-gauche, chip en
 *            haut-droite, carte stats en bas-droite), fidèle au design importé.
 *
 * Le téléphone est dimensionné en pixels « natifs » (288×560) ; sous lg il est mis
 * à l'échelle via `scale` (origine bas) pour rester net sans recalculer chaque cote.
 * Les textes vivent dans `heroShowcase` (copy.ts) ; seule la géométrie décorative
 * (barres du graphe) est locale.
 */
import { Image } from "astro:assets";
import Logo from "@/components/Logo.astro";
import GrainOverlay from "@/components/GrainOverlay.astro";
import { hero, heroShowcase } from "@/content/copy";
import heroCycling from "@/assets/hero-cycling.webp";

const { contact, dayLabel, inputPlaceholder, chat, chip, stats } = heroShowcase;

// Barres du mini-graphe « semaine » (purement décoratif). `on` = séance (encre).
const bars = [
  { h: 11, on: false },
  { h: 26, on: true },
  { h: 11, on: false },
  { h: 9, on: false },
  { h: 22, on: true },
  { h: 11, on: false },
  { h: 34, on: true },
];
---

<div class="relative h-[clamp(420px,82vw,560px)] lg:h-[600px]">
  {/* Carte photo plein cadre */}
  <div
    class="absolute inset-0 overflow-hidden rounded-3xl shadow-[0_40px_80px_-30px_rgba(20,24,40,0.45)]"
  >
    <Image
      src={heroCycling}
      alt="Cyclistes sur une route de col au lever du soleil"
      widths={[640, 960, 1320, 1980]}
      sizes="(min-width: 1024px) 1320px, 100vw"
      class="absolute inset-0 h-full w-full object-cover"
      style="object-position:center 38%;"
      loading="eager"
      fetchpriority="high"
    />
    {/* Dégradés sombres pour asseoir le label et donner du contraste */}
    <div
      class="absolute inset-0"
      style="background:linear-gradient(180deg,rgba(8,10,20,0.34) 0%,rgba(8,10,20,0) 26%),linear-gradient(95deg,rgba(8,10,20,0.30) 0%,rgba(8,10,20,0) 46%);"
    >
    </div>
    <GrainOverlay id="inigo-grain-hero" opacity={0.22} class="mix-blend-overlay" />
    <span
      class="eyebrow absolute left-6 top-6 text-white/90 [letter-spacing:0.22em] [text-shadow:0_1px_8px_rgba(0,0,0,0.4)] sm:left-8 sm:top-7"
    >
      {hero.signature}
    </span>
  </div>

  {/* Téléphone WhatsApp — centré/réduit sous lg, débordant en bas-gauche dès lg */}
  <div
    class="absolute bottom-0 left-1/2 z-[4] -translate-x-1/2 origin-bottom scale-[0.62] md:scale-[0.82] lg:bottom-[-72px] lg:left-[62px] lg:translate-x-0 lg:scale-100"
  >
    <div
      class="inigo-float-phone"
      style="width:288px; height:560px; border-radius:52px; padding:8px; background:#0b0b0c; box-shadow:0 60px 100px -32px rgba(10,12,24,0.6),0 0 0 1.5px #303137,inset 0 0 3px rgba(255,255,255,0.12);"
    >
      <div
        style="position:relative; width:100%; height:100%; background:#E9E2D8; border-radius:44px; overflow:hidden; display:flex; flex-direction:column;"
      >
        {/* Encoche */}
        <div
          style="position:absolute; top:13px; left:50%; transform:translateX(-50%); width:88px; height:26px; background:#000; border-radius:14px; z-index:7; display:flex; align-items:center; justify-content:flex-end; padding-right:9px;"
        >
          <div
            style="width:7px; height:7px; border-radius:50%; background:#12241d; box-shadow:inset 0 0 0 1px rgba(95,135,115,0.4);"
          >
          </div>
        </div>

        {/* Status bar */}
        <div
          style="position:absolute; top:0; left:0; right:0; height:46px; z-index:6; display:flex; align-items:center; justify-content:space-between; padding:16px 24px 0; font-size:13px; font-weight:600; letter-spacing:-0.01em; color:#0c0d10;"
        >
          <span>9:41</span>
          <div style="display:flex; align-items:center; gap:6px;">
            <div style="display:flex; align-items:flex-end; gap:2px; height:10px;">
              <div style="width:3px; height:4px; background:#0c0d10; border-radius:1px;"></div>
              <div style="width:3px; height:6px; background:#0c0d10; border-radius:1px;"></div>
              <div style="width:3px; height:8px; background:#0c0d10; border-radius:1px;"></div>
              <div style="width:3px; height:10px; background:#0c0d10; border-radius:1px;"></div>
            </div>
            <svg width="16" height="12" viewBox="0 0 24 24" fill="#0c0d10">
              <path d="M12 17.5a2.2 2.2 0 1 0 0 4.4 2.2 2.2 0 0 0 0-4.4z"></path>
              <path d="M12 10.2c2.7 0 5.2 1.05 7 2.8l-2.1 2.15A6.9 6.9 0 0 0 12 13.1a6.9 6.9 0 0 0-4.9 2.05L5 13a9.9 9.9 0 0 1 7-2.8z"></path>
              <path d="M12 3.4c4.4 0 8.4 1.78 11.3 4.66l-2.1 2.14A13.9 13.9 0 0 0 12 6.3a13.9 13.9 0 0 0-9.2 3.9L.7 8.06A15.9 15.9 0 0 1 12 3.4z"></path>
            </svg>
            <div style="display:flex; align-items:center; gap:1.5px;">
              <div
                style="width:22px; height:11px; border:1.2px solid rgba(12,13,16,0.4); border-radius:3.5px; padding:1.4px;"
              >
                <div style="width:72%; height:100%; background:#0c0d10; border-radius:1.5px;"></div>
              </div>
              <div
                style="width:1.5px; height:4px; background:rgba(12,13,16,0.4); border-radius:0 1.5px 1.5px 0;"
              >
              </div>
            </div>
          </div>
        </div>

        {/* En-tête contact */}
        <div
          style="background:#F6F5F3; padding:50px 14px 10px; display:flex; align-items:center; gap:10px; border-bottom:1px solid rgba(0,0,0,0.06);"
        >
          <svg
            width="11"
            height="18"
            viewBox="0 0 11 18"
            fill="none"
            stroke="#1fae54"
            stroke-width="2.2"
            stroke-linecap="round"
            stroke-linejoin="round"
            style="flex-shrink:0;"
          >
            <path d="M9 1.5 2 9l7 7.5"></path>
          </svg>
          <div
            style="width:36px; height:36px; border-radius:50%; background:#0c0d10; display:flex; align-items:center; justify-content:center; flex-shrink:0;"
          >
            <Logo variant="mark" class="!h-3.5 w-auto text-white" />
          </div>
          <div style="flex:1; min-width:0;">
            <div style="font-size:15px; font-weight:700; color:#0c0d10; line-height:1.15;">
              {contact.name}
            </div>
            <div style="font-size:11.5px; color:#1fae54; line-height:1.25; font-weight:500;">
              {contact.status}
            </div>
          </div>
          <svg
            width="21"
            height="21"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#1fae54"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M23 7l-7 5 7 5V7z"></path>
            <rect x="1" y="5" width="15" height="14" rx="2.5"></rect>
          </svg>
          <svg
            width="19"
            height="19"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#1fae54"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"
            ></path>
          </svg>
        </div>

        {/* Fil de conversation */}
        <div
          style="flex:1; padding:14px 12px 10px; display:flex; flex-direction:column; gap:9px; overflow:hidden;"
        >
          <div
            style="align-self:center; background:rgba(255,255,255,0.7); color:#5b6168; font-size:10px; font-weight:600; letter-spacing:0.04em; padding:4px 10px; border-radius:8px; text-transform:uppercase;"
          >
            {dayLabel}
          </div>

          {
            chat.map((message) =>
              message.from === "out" ? (
                <div style="align-self:flex-end; max-width:82%; background:#D9FDD3; color:#111b21; font-size:13px; line-height:1.36; padding:7px 10px 5px; border-radius:11px; border-top-right-radius:3px; box-shadow:0 1px 1px rgba(0,0,0,0.08);">
                  {message.text}
                  <span style="display:flex; align-items:center; justify-content:flex-end; gap:3px; font-size:9.5px; color:#5aa37a; margin-top:1px;">
                    {message.time}
                    <svg
                      width="14"
                      height="9"
                      viewBox="0 0 16 11"
                      fill="none"
                      stroke="#53BDEB"
                      stroke-width="1.6"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M1 5.5l3 3 6-7" />
                      <path d="M6 8.5l1 .5 6-7" />
                    </svg>
                  </span>
                </div>
              ) : (
                <div style="align-self:flex-start; max-width:82%; background:#fff; color:#111b21; font-size:13px; line-height:1.36; padding:7px 10px 5px; border-radius:11px; border-top-left-radius:3px; box-shadow:0 1px 1px rgba(0,0,0,0.08);">
                  {message.text}
                  <span style="display:block; text-align:right; font-size:9.5px; color:#9aa0a6; margin-top:1px;">
                    {message.time}
                  </span>
                </div>
              ),
            )
          }
        </div>

        {/* Barre de saisie */}
        <div style="padding:9px 10px 10px; display:flex; align-items:center; gap:7px;">
          <div
            style="flex:1; background:#fff; border-radius:18px; padding:9px 12px; display:flex; align-items:center; gap:8px; box-shadow:0 1px 1px rgba(0,0,0,0.06);"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8a9099" stroke-width="2">
              <circle cx="12" cy="12" r="9"></circle>
              <circle cx="9" cy="10" r="0.6" fill="#8a9099"></circle>
              <circle cx="15" cy="10" r="0.6" fill="#8a9099"></circle>
              <path d="M8.5 14.5c1 1.2 2.2 1.8 3.5 1.8s2.5-.6 3.5-1.8" stroke-linecap="round"></path>
            </svg>
            <span style="font-size:13px; color:#9aa0a6;">{inputPlaceholder}</span>
          </div>
          <div
            style="width:38px; height:38px; border-radius:50%; background:#1fae54; display:flex; align-items:center; justify-content:center; flex-shrink:0;"
          >
            <svg width="17" height="17" viewBox="0 0 24 24" fill="#fff">
              <path d="M2 21l21-9L2 3v7l15 2-15 2v7z"></path>
            </svg>
          </div>
        </div>

        {/* Home indicator */}
        <div style="height:22px; display:flex; align-items:center; justify-content:center;">
          <div style="width:108px; height:4px; border-radius:3px; background:#0c0d10; opacity:0.85;"></div>
        </div>
      </div>
    </div>
  </div>

  {/* Chip de notification (desktop uniquement) */}
  <div
    class="inigo-float absolute right-[118px] top-[62px] z-[5] hidden w-[248px] items-center gap-[11px] rounded-2xl bg-white p-3 shadow-[0_24px_50px_-18px_rgba(10,12,24,0.45),0_0_0_1px_rgba(0,0,0,0.04)] lg:flex"
  >
    <div
      style="width:40px; height:40px; border-radius:12px; background:#0c0d10; display:flex; align-items:center; justify-content:center; flex-shrink:0;"
    >
      <Logo variant="mark" class="!h-4 w-auto text-white" />
    </div>
    <div style="flex:1; min-width:0;">
      <div style="display:flex; align-items:center; justify-content:space-between; gap:6px;">
        <span style="font-size:13.5px; font-weight:700; color:#0c0d10;">{chip.name}</span>
        <span style="font-size:11px; color:#9aa0a6;">{chip.time}</span>
      </div>
      <div
        style="font-size:12.5px; color:#5b6168; line-height:1.3; margin-top:1px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"
      >
        {chip.text}
      </div>
    </div>
  </div>

  {/* Carte stats « semaine » (desktop uniquement) */}
  <div
    class="absolute bottom-[52px] right-[62px] z-[5] hidden w-[208px] rounded-2xl px-4 py-3.5 shadow-[0_24px_50px_-18px_rgba(10,12,24,0.45),0_0_0_1px_rgba(0,0,0,0.04)] backdrop-blur-[10px] lg:block"
    style="background:rgba(255,255,255,0.92);"
  >
    <div style="display:flex; align-items:center; gap:7px; margin-bottom:9px;">
      <span class="inigo-pulse" style="width:7px; height:7px; border-radius:50%; background:#25D366;"></span>
      <span class="eyebrow text-[10px] [letter-spacing:0.16em]" style="color:#8a8d93;">{stats.eyebrow}</span>
    </div>
    <div style="font-size:16.5px; font-weight:700; color:#0c0d10; line-height:1.15; margin-bottom:12px;">
      {stats.title}
    </div>
    <div style="display:flex; align-items:flex-end; gap:6px; height:34px;">
      {
        bars.map((bar) => (
          <div
            style={`flex:1; height:${bar.h}px; border-radius:3px; background:${bar.on ? "#0c0d10" : "#e3dfd8"};`}
          />
        ))
      }
    </div>
    <div
      class="font-mono"
      style="display:flex; justify-content:space-between; font-size:9px; color:#b3b6bb; margin-top:7px;"
    >
      {stats.days.map((day) => <span>{day}</span>)}
    </div>
  </div>
</div>
