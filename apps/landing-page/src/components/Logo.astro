---
/**
 * Logo Inigo (assets v2). `variant="full"` = lockup marque + wordmark « inigo » ;
 * `variant="mark"` = la marque seule (deux traits ascendants). Monochrome `currentColor`
 * (suit la couleur de texte du parent), sans dégradé. Poids de trait (40) porté par l'asset.
 * Le `<svg>` racine clippe à son viewBox → pas d'id dupliqué quand le logo se répète.
 */
interface Props {
  class?: string;
  variant?: "full" | "mark";
}
const { class: className, variant = "full" } = Astro.props;
---

{
  variant === "mark" ? (
    <svg
      class:list={["h-7 w-auto", className]}
      viewBox="0 0 512 512"
      fill="none"
      stroke="currentColor"
      stroke-width="40"
      stroke-linecap="round"
      role="img"
      aria-label="Inigo"
      xmlns="http://www.w3.org/2000/svg"
    >
      <line x1="47.5676" y1="393.942" x2="226.799" y2="255.147" />
      <line x1="272.218" y1="372.599" x2="457.313" y2="89.7823" />
    </svg>
  ) : (
    <span class:list={["inline-flex items-center gap-2.5", className]} role="img" aria-label="Inigo">
      {/* Marque (deux traits ascendants), viewBox croppé sur le contenu pour un espacement net. */}
      <svg
        class="h-8 w-auto"
        viewBox="28 70 450 344"
        fill="none"
        stroke="currentColor"
        stroke-width="40"
        stroke-linecap="round"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
      >
        <line x1="47.5676" y1="393.942" x2="226.799" y2="255.147" />
        <line x1="272.218" y1="372.599" x2="457.313" y2="89.7823" />
      </svg>
      {/* Wordmark « inigo » (stroke/poids hérités du <svg>). */}
      <svg
        class="h-9 w-auto"
        viewBox="0 0 926 334"
        fill="none"
        stroke="currentColor"
        stroke-width="40"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
      >
        <line x1="31" y1="81.9966" x2="31.0275" y2="243.997" />
        <line x1="419" y1="11" x2="419" y2="51" />
        <line x1="31" y1="11" x2="31" y2="51" />
        <line x1="419" y1="81.9966" x2="419.027" y2="243.997" />
        <line x1="149.999" y1="144.196" x2="149.019" y2="244.196" />
        <path d="M280 145C280 70.585 150 70.0822 150 145" />
        <line x1="280.468" y1="143.892" x2="281" y2="243.894" />
        <path d="M577.957 226.101C580.454 226.095 665.845 232.729 665.994 176.191" />
        <path d="M577.724 95.9692C503.31 96.2703 503.333 226.399 578.251 226.096" />
        <line x1="575.813" y1="95.9369" x2="675.812" y2="95.0009" />
        <path d="M577.724 285.927C503.309 286.229 503.333 416.4 578.25 416.096" />
        <line x1="575.813" y1="285.937" x2="675.812" y2="285.001" />
        <circle cx="830" cy="153" r="69.5" stroke-width="35" />
      </svg>
    </span>
  )
}
