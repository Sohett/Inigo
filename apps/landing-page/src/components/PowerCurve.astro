---
/**
 * Élément signature : courbe puissance–durée (mean-max), façon Garmin / Intervals.icu,
 * retravaillée (trait net + aire en dégradé ; le grain est posé par le parent).
 * Décroît de la gauche (puissance max, courte durée) vers la droite (puissance soutenue) :
 * une lecture « données » vraie pour un coach d'endurance, pas de la déco.
 *
 * `pathLength="1000"` normalise la longueur → le tracé CSS (.draw-stroke) fonctionne
 * quelle que soit la mise à l'échelle du SVG.
 */
interface Props {
  class?: string;
  /** Anime le tracé une fois au chargement (CSS pur). */
  draw?: boolean;
  /** Délai du tracé, en ms. */
  drawDelay?: number;
  strokeWidth?: number;
  /** Aire dégradée sous la courbe. */
  area?: boolean;
  /** id unique du dégradé d'aire si plusieurs courbes coexistent. */
  fillId?: string;
}
const {
  class: className,
  draw = false,
  drawDelay = 250,
  strokeWidth = 2,
  area = false,
  fillId = "inigo-curve-fill",
} = Astro.props;

// Courbe puissance–durée : pic à gauche, longue traîne décroissante vers la droite.
const line = "M0 38 C 120 92 244 150 420 174 C 600 198 766 208 1000 214";
const fillPath = `${line} L1000 240 L0 240 Z`;
---

<svg
  class={className}
  viewBox="0 0 1000 240"
  fill="none"
  preserveAspectRatio="none"
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  {
    area && (
      <>
        <defs>
          <linearGradient id={fillId} x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="currentColor" stop-opacity="0.24" />
            <stop offset="100%" stop-color="currentColor" stop-opacity="0" />
          </linearGradient>
        </defs>
        <path d={fillPath} fill={`url(#${fillId})`} stroke="none" />
      </>
    )
  }
  <path
    d={line}
    pathLength="1000"
    stroke="currentColor"
    stroke-width={strokeWidth}
    stroke-linecap="round"
    stroke-linejoin="round"
    vector-effect="non-scaling-stroke"
    class={draw ? "draw-stroke" : undefined}
    style={draw ? `--draw-delay:${drawDelay}ms` : undefined}
  />
</svg>
