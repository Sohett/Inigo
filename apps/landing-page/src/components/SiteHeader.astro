---
import Logo from "@/components/Logo.astro";
import { nav } from "@/content/copy";
---

<header id="top" data-site-header class="site-header sticky top-0 z-40">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a
      href="#top"
      class="text-foreground transition-opacity hover:opacity-70"
      aria-label="Inigo, accueil"
    >
      <Logo />
    </a>

    <nav aria-label="Navigation principale" class="hidden items-center gap-8 md:flex">
      {
        nav.items.map((item) => (
          <a
            href={item.href}
            class="text-sm text-muted-foreground underline-offset-4 transition hover:text-foreground hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-encre/40 focus-visible:ring-offset-2 focus-visible:ring-offset-background"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      {/* Place réservée pour un futur bouton « Connexion » — non câblé. */}
      <span
        aria-hidden="true"
        tabindex="-1"
        class="pointer-events-none hidden select-none text-sm text-muted-foreground/55 md:inline"
      >
        {nav.login.label}
      </span>
      <a
        href={nav.cta.href}
        class="inline-flex h-9 items-center rounded-lg bg-encre px-4 text-sm font-semibold text-white transition hover:bg-encre/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-encre focus-visible:ring-offset-2 focus-visible:ring-offset-background"
      >
        {nav.cta.label}
      </a>
    </div>
  </div>
</header>

<script>
  // Navbar transparente en haut, verre clair dès qu'on scrolle (classe .is-scrolled).
  const header = document.querySelector<HTMLElement>("[data-site-header]");
  if (header) {
    const sync = () => header.classList.toggle("is-scrolled", window.scrollY > 8);
    sync();
    window.addEventListener("scroll", sync, { passive: true });
  }
</script>
