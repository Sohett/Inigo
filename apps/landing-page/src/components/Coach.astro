---
import { coach } from "@/content/copy";
---

<section id="coach" class="scroll-mt-20 bg-background px-6">
  <div class="mx-auto max-w-3xl py-24 sm:py-32">
    <p class="eyebrow reveal text-encre-soft">{coach.eyebrow}</p>
    <h2 class="reveal mt-5 text-3xl font-bold leading-tight sm:text-4xl">{coach.title}</h2>
    <p class="reveal mt-6 text-lg leading-relaxed text-muted-foreground">{coach.body}</p>
  </div>
</section>
