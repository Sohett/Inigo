# --- Intervals.icu API credentials (server-side only, never expose to the client) ---
# Create an API key at: Intervals.icu > Settings > Developer
INTERVALS_API_KEY=your_intervals_icu_api_key
# Your athlete id (e.g. "i123456"). Found in the Intervals.icu URL or athlete settings.
INTERVALS_ATHLETE_ID=i000000

# --- MCP endpoint protection ---
# Secret bearer token the Managed Agent must present to call this MCP server.
# Generate a strong random value, e.g.: openssl rand -hex 32
MCP_BEARER_TOKEN=change_me_to_a_long_random_secret

# --- Feature flags ---
# Set to "true" to expose the event write tools (create/update/delete). Default: false.
ENABLE_WRITE_TOOLS=false

# --- Optional overrides ---
# Base URL of the Intervals.icu API. Defaults to the production URL below.
INTERVALS_BASE_URL=https://intervals.icu/api/v1
